PORT=8000
DB_URL=postgres://username:password@localhost:5432/database_name
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
JWT_SECRET=your_jwt_secret_key
PRIMARY_EMAIL=your_email@example.com
PRIMARY_EMAIL_PASSWORD=your_email_password
FRONTEND_URL=http://localhost:3000

# GitHub App Configuration
githubwebhooksecret=your_github_webhook_secret

# ngrok Configuration
ngrok=your_ngrok_auth_token
webhookurl=https://your-ngrok-url.ngrok-free.dev/v1/github/webhook
publiclink=https://github.com/apps/your-github-app

# GitHub App Credentials
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Azure Embedding Configuration
AZURE_EMBEDDING_ENDPOINT=your_azure_embedding_endpoint
AZURE_EMBEDDING_API_KEY=your_azure_embedding_api_key
