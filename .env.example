PORT=8000
DB_URL=postgres://username:password@localhost:5432/database_name
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
JWT_SECRET=your_jwt_secret_key
PRIMARY_EMAIL=your_email@example.com
PRIMARY_EMAIL_PASSWORD=your_email_password
FRONTEND_URL=http://localhost:3000

# Google OAuth login
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth login
GITHUB_AUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_AUTH_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_AUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/github/callback
